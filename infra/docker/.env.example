# -----------------------------
# Core platform secrets
# -----------------------------
POSTGRES_PASSWORD=change_me_postgres_supersecret
REDIS_PASSWORD=change_me_redis_supersecret

# -----------------------------
# MinIO (S3-compatible)
# -----------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_supersecret

# -----------------------------
# Keycloak admin + DB password
# -----------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_keycloak_admin_supersecret
KEYCLOAK_DB_PASSWORD=change_me_keycloak_db_supersecret

# Optional override (compose defaults to keycloak container realm URL)
# If you later front Keycloak via gateway/hostname, set this accordingly.
# OIDC_ISSUER=http://localhost:8080/realms/platform

# -----------------------------
# Optional: Audit anchoring feature toggle
# -----------------------------
ANCHOR_ENABLED=false

# -----------------------------
# Observability (Grafana)
# -----------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_supersecret

# Keycloak confidential client secret for platform-services
KEYCLOAK_PLATFORM_SERVICES_CLIENT_SECRET=change_me_services_client_secret
